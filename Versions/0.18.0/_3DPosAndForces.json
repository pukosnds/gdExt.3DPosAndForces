    {
      "fullName": "Positioning an object relative to the camera Pos and Angle",
      "functionType": "Action",
      "name": "positioningCamera",
      "sentence": "Position object _PARAM1_ at the center of camera with distance _PARAM2_, with Xoffset _PARAM3_, Yoffset _PARAM4_, with lerp (float) _PARAM6_",
      "events": [
        {
          "type": "BuiltinCommonInstructions::Standard",
          "conditions": [
            {
              "type": {
                "value": "NumberVariable"
              },
              "parameters": [
                "lerp",
                "=",
                "-1"
              ]
            }
          ],
          "actions": [
            {
              "type": {
                "value": "SetCenter"
              },
              "parameters": [
                "Object",
                "=",
                "CameraCenterX()+ (Distance * cos(ToRad(CameraAngle() - 90)) * cos(ToRad(Scene3D::CameraRotationX() - 90))) \n+ (HorizontalOffset * cos(ToRad(CameraAngle()))) \n+ (VerticalOffset * cos(ToRad(CameraAngle() - 90)) * sin(ToRad(Scene3D::CameraRotationX() - 90)))",
                "=",
                "CameraCenterY() \n+ (Distance * sin(ToRad(CameraAngle() - 90)) * cos(ToRad(Scene3D::CameraRotationX() - 90))) \n+ (HorizontalOffset * sin(ToRad(CameraAngle()))) \n+ (VerticalOffset * sin(ToRad(CameraAngle() - 90)) * sin(ToRad(Scene3D::CameraRotationX() - 90)))"
              ]
            },
            {
              "type": {
                "value": "Scene3D::Base3DBehavior::SetCenterZ"
              },
              "parameters": [
                "Object",
                "Object3D",
                "=",
                "Scene3D::CameraZ() \n+ (Distance * sin(ToRad(Scene3D::CameraRotationX() - 90))) \n+ (VerticalOffset * cos(ToRad(Scene3D::CameraRotationX() - 90)))"
              ]
            }
          ]
        },
        {
          "type": "BuiltinCommonInstructions::Standard",
          "conditions": [
            {
              "type": {
                "value": "NumberVariable"
              },
              "parameters": [
                "lerp",
                "!=",
                "-1"
              ]
            }
          ],
          "actions": [
            {
              "type": {
                "value": "SetCenter"
              },
              "parameters": [
                "Object",
                "=",
                "lerp(Object.CenterX(), CameraCenterX()+ Distance * cos(ToRad((CameraAngle()-90))) * cos(ToRad((Scene3D::CameraRotationX()-90))),lerp)",
                "=",
                "lerp(Object.CenterY(), CameraCenterY()+ Distance * sin(ToRad((CameraAngle()-90))) * cos(ToRad((Scene3D::CameraRotationX()-90))), lerp)"
              ]
            },
            {
              "type": {
                "value": "Scene3D::Base3DBehavior::SetCenterZ"
              },
              "parameters": [
                "Object",
                "Object3D",
                "=",
                "lerp(Object.Object3D::CenterZ(), Scene3D::CameraZ() + (Distance * sin(ToRad(Scene3D::CameraRotationX()-90))), lerp)"
              ]
            }
          ]
        }
      ],
      "parameters": [
        {
          "description": "Object",
          "name": "Object",
          "type": "objectList"
        },
        {
          "description": "Distance between Camera and Object",
          "name": "Distance",
          "type": "expression"
        },
        {
          "description": "2D pos in X Axis, 0 is center",
          "name": "HorizontalOffset",
          "type": "expression"
        },
        {
          "description": "2D pos in Y Axis, 0 is center",
          "name": "VerticalOffset",
          "type": "expression"
        },
        {
          "description": "3D capability",
          "name": "Object3D",
          "supplementaryInformation": "Scene3D::Base3DBehavior",
          "type": "behavior"
        },
        {
          "description": "to smooth",
          "name": "lerp",
          "type": "expression"
        }
      ],
      "objectGroups": []
    },
    {
      "fullName": "Positioning an object relative to the camera Pos and Angle(Physics)",
      "functionType": "Action",
      "name": "positioningCameraPhysics",
      "sentence": "Position object _PARAM1_ at the center of camera with distance _PARAM2_, with Xoffset _PARAM3_, Yoffset _PARAM4_, with lerp (float) _PARAM6_ with Physics",
      "events": [
        {
          "type": "BuiltinCommonInstructions::Standard",
          "conditions": [],
          "actions": [
            {
              "type": {
                "value": "Physics3D::Physics3DBehavior::SetLinearVelocityX"
              },
              "parameters": [
                "Object",
                "Physics3D",
                "=",
                "((CameraCenterX() + (Distance * cos(ToRad(CameraAngle() - 90)) * cos(ToRad(Scene3D::CameraRotationX() - 90))) + (HorizontalOffset * cos(ToRad(CameraAngle()))) + (VerticalOffset * cos(ToRad(CameraAngle() - 90)) * sin(ToRad(Scene3D::CameraRotationX() - 90)))) - Object.CenterX()) * lerp"
              ]
            },
            {
              "type": {
                "value": "Physics3D::Physics3DBehavior::SetLinearVelocityY"
              },
              "parameters": [
                "Object",
                "Physics3D",
                "=",
                "((CameraCenterY() + (Distance * sin(ToRad(CameraAngle() - 90)) * cos(ToRad(Scene3D::CameraRotationX() - 90))) + (HorizontalOffset * sin(ToRad(CameraAngle()))) + (VerticalOffset * sin(ToRad(CameraAngle() - 90)) * sin(ToRad(Scene3D::CameraRotationX() - 90)))) - Object.CenterY()) * lerp"
              ]
            },
            {
              "type": {
                "value": "Physics3D::Physics3DBehavior::SetLinearVelocityZ"
              },
              "parameters": [
                "Object",
                "Physics3D",
                "=",
                "((Scene3D::CameraZ() + (Distance * sin(ToRad(Scene3D::CameraRotationX() - 90))) + (VerticalOffset * cos(ToRad(Scene3D::CameraRotationX() - 90)))) - Object.Object3D::CenterZ()) * lerp"
              ]
            }
          ]
        }
      ],
      "parameters": [
        {
          "description": "Object",
          "name": "Object",
          "type": "objectList"
        },
        {
          "description": "Distance between Camera and Object",
          "name": "Distance",
          "type": "expression"
        },
        {
          "description": "2D pos in X Axis, 0 is center",
          "name": "HorizontalOffset",
          "type": "expression"
        },
        {
          "description": "2D pos in Y Axis, 0 is center",
          "name": "VerticalOffset",
          "type": "expression"
        },
        {
          "description": "3D capability",
